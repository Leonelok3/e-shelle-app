# ================================================================
# EduCam Pro — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs réelles
# NE JAMAIS committer le fichier .env avec de vraies clés !
# ================================================================

# ── ORANGE MONEY CAMEROUN ────────────────────────────────────────
ORANGE_MONEY_API_KEY=votre_api_key_orange
ORANGE_MONEY_API_SECRET=votre_api_secret_orange
ORANGE_MONEY_MERCHANT_KEY=votre_merchant_key_orange

# ── MTN MOBILE MONEY ────────────────────────────────────────────
MTN_MOMO_SUBSCRIPTION_KEY=votre_subscription_key_mtn
MTN_MOMO_API_USER=votre_api_user_uuid
MTN_MOMO_API_KEY=votre_api_key_mtn
MTN_MOMO_ENVIRONMENT=sandbox   # 'sandbox' ou 'production'

# ── WEBHOOK SÉCURITÉ ────────────────────────────────────────────
EDU_WEBHOOK_HMAC_SECRET=une_cle_secrete_longue_et_aleatoire_32chars_min

# ── SMS (TWILIO - optionnel) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── SMS (ORANGE SMS API - optionnel) ────────────────────────────
ORANGE_SMS_API_KEY=

# ── URL DU SITE (pour les webhooks) ─────────────────────────────
SITE_URL=https://e-shelle.com
