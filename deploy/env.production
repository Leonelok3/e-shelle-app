# ============================================================
#  .env  — PRODUCTION   (copier vers /home/eshelle/app/.env)
#  NE JAMAIS committer ce fichier dans Git
# ============================================================

# --- Django core ---
DJANGO_SECRET_KEY=REMPLACER_PAR_UNE_CLE_DE_50_CARACTERES_ALEATOIRES
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=e-shelle.com,www.e-shelle.com

# --- Base de données PostgreSQL ---
DATABASE_URL=postgres://eshelle_user:MOT_DE_PASSE_DB@localhost:5432/eshelle_db

# --- Anthropic / Claude AI ---
ANTHROPIC_API_KEY=sk-ant-VOTRE_VRAIE_CLE_ICI

# --- Email SMTP (Gmail ou Mailgun) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=contact@e-shelle.com
EMAIL_HOST_PASSWORD=MOT_DE_PASSE_APPLICATION_GMAIL
DEFAULT_FROM_EMAIL=E-Shelle <contact@e-shelle.com>

# --- Sécurité cookies HTTPS ---
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=63072000
